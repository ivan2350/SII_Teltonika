#!/usr/bin/env python3
import time
import subprocess
from pymodbus.client import ModbusTcpClient

# ================= CONFIG =================

MODBUS_HOST = "127.0.0.1"
MODBUS_PORT = 502
MODBUS_ID = 32

INTERVALO_NORMAL = 60
INTERVALO_ERROR = 5
RETARDO_REARRANQUE = 180
MAX_FALLOS_MODBUS = 30

TIEMPO_DIAGNOSTICO = 3600  # 1 hora

DO_MOTOR = "ioman.gpio.dio0"
DI_DIAG = "ioman.gpio.dio1"

# ================= ESTADO =================

control_motor = False
tiempo_ultimo_apagado = None

fallos_modbus = 0
intervalo_actual = INTERVALO_NORMAL

modo_diagnostico = False
tiempo_inicio_diag = None

estado_diag_anterior = None  # para detectar flanco

client = ModbusTcpClient(MODBUS_HOST, port=MODBUS_PORT, timeout=2)

# ================= UTIL =================

def ts():
    return time.strftime("%d-%m-%Y %H:%M:%S")

# ================= GPIO =================

def set_motor(valor: bool, motivo=""):
    global control_motor, tiempo_ultimo_apagado

    if control_motor == valor:
        return

    cmd = f"ubus call {DO_MOTOR} update '{{\"value\":\"{1 if valor else 0}\"}}'"
    subprocess.run(cmd, shell=True, check=False)

    control_motor = valor

    if not valor:
        tiempo_ultimo_apagado = time.time()
        print(f"[{ts()}] 🔴 CONTROL APAGADO → {motivo}")
    else:
        print(f"[{ts()}] 🟢 CONTROL ENCENDIDO → {motivo}")

def leer_di():
    try:
        out = subprocess.check_output(
            f"ubus call {DI_DIAG} status", shell=True
        ).decode()
        return '"value": "1"' in out
    except:
        return False

# ================= MODBUS =================

def leer_flotadores():
    if not client.connect():
        raise Exception("No conecta Modbus TCP")

    rr = client.read_discrete_inputs(0, 2, unit=MODBUS_ID)

    if rr.isError():
        raise Exception("Error lectura Modbus")

    return rr.bits[0], rr.bits[1]

def reiniciar_modbus():
    print(f"[{ts()}] 🔄 Reiniciando Modbus TCP...")
    try:
        client.close()
    except:
        pass
    time.sleep(2)

# ================= INICIO =================

print(f"[{ts()}] 🚀 Sistema iniciado")

while True:
    try:
        ahora = time.time()

        # ===== DETECCIÓN DE FLANCO =====
        estado_diag_actual = leer_di()

        if estado_diag_anterior is None:
            estado_diag_anterior = estado_diag_actual

        if estado_diag_actual != estado_diag_anterior:
            # FLANCO DETECTADO
            modo_diagnostico = True
            tiempo_inicio_diag = ahora

            print(f"[{ts()}] 🧪 MODO DIAGNÓSTICO ACTIVADO (por cambio de entrada)")

        estado_diag_anterior = estado_diag_actual

        # ===== CONTROL DE TIEMPO DIAGNÓSTICO =====
        if modo_diagnostico and tiempo_inicio_diag:
            if ahora - tiempo_inicio_diag >= TIEMPO_DIAGNOSTICO:
                modo_diagnostico = False
                print(f"[{ts()}] 🟢 MODO DIAGNÓSTICO FINALIZADO (1 hora)")

        # ===== LECTURA MODBUS =====
        flotador_bajo, flotador_alto = leer_flotadores()

        fallos_modbus = 0

        intervalo_actual = INTERVALO_ERROR if modo_diagnostico else INTERVALO_NORMAL

        # ===== LÓGICA =====
        if flotador_alto and not flotador_bajo:
            estado = "⚠️ Inconsistencia"
            if control_motor:
                set_motor(False, estado)

        elif flotador_alto and flotador_bajo:
            estado = "🟦 Tanque lleno"
            if control_motor:
                set_motor(False, estado)

        elif not flotador_bajo and not flotador_alto:
            if control_motor:
                estado = "💧 Llenando"
            else:
                if tiempo_ultimo_apagado is None or \
                   (ahora - tiempo_ultimo_apagado) >= RETARDO_REARRANQUE:
                    estado = "▶️ Arranque permitido"
                    set_motor(True, "Tanque vacío")
                else:
                    restante = int(RETARDO_REARRANQUE - (ahora - tiempo_ultimo_apagado))
                    estado = f"⏳ Esperando ({restante}s)"
        else:
            estado = "🟡 Nivel medio"

        print(
            f"[{ts()}] "
            f"🟢 Bajo: {flotador_bajo} | "
            f"🔵 Alto: {flotador_alto} | "
            f"🎛️ Control: {'ON' if control_motor else 'OFF'} | "
            f"🧪 Diagnóstico: {'ON' if modo_diagnostico else 'OFF'} | "
            f"{estado}"
        )

        time.sleep(intervalo_actual)

    except Exception as e:
        fallos_modbus += 1
        modo_diagnostico = True
        intervalo_actual = INTERVALO_ERROR

        print(f"[{ts()}] ❌ ERROR Modbus ({fallos_modbus}) → Diagnóstico activo")

        if fallos_modbus >= MAX_FALLOS_MODBUS:
            if control_motor:
                set_motor(False, "Falla comunicación")

            reiniciar_modbus()
            fallos_modbus = 0

        time.sleep(intervalo_actual)
