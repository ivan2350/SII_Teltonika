//ESTE CODIGO SE HIZO HACIENDO QUE COMUNIQUE POR TCP SERVER Y DE AHI LEER EL DATO, YA QUE POR PYTHON NO ESTA LEYENDO EL DATO A USAR, ESTO NOS EVITA ERRORES CON ACTUALIZACION DE DRIVERS Y LIBRERIAS DE PYTHON

#!/usr/bin/env python3
import time
import subprocess
from pymodbus.client import ModbusTcpClient

# ================= CONFIGURACIÓN =================

MODBUS_HOST = "127.0.0.1"
MODBUS_PORT = 502
MODBUS_ID = 32   # ID del Ebyte

INTERVALO_NORMAL = 60
INTERVALO_ERROR = 5
RETARDO_REARRANQUE = 180
MAX_FALLOS_MODBUS = 30

DO_MOTOR = "ioman.gpio.dio0"
DI_MOTOR = "ioman.gpio.dio1"

# ================= ESTADO =================

control_motor = False
motor_estado = False

tiempo_ultimo_apagado = None
fallos_modbus = 0
estado_proceso = "Inicializando"
intervalo_actual = INTERVALO_NORMAL

client = ModbusTcpClient(MODBUS_HOST, port=MODBUS_PORT, timeout=2)

# ================= UTIL =================

def ts():
    return time.strftime("%d-%m-%Y %H:%M:%S")

# ================= GPIO =================

def set_motor(valor: bool, motivo=None):
    global control_motor, tiempo_ultimo_apagado

    if control_motor == valor:
        return

    cmd = f"ubus call {DO_MOTOR} update '{{\"value\":\"{1 if valor else 0}\"}}'"
    subprocess.run(cmd, shell=True, check=False)

    control_motor = valor

    if not valor:
        tiempo_ultimo_apagado = time.time()
        if motivo:
            print(f"[{ts()}] 🔴 CONTROL APAGADO → {motivo}")
    else:
        if motivo:
            print(f"[{ts()}] 🟢 CONTROL ENCENDIDO → {motivo}")

def leer_motor_estado():
    try:
        out = subprocess.check_output(
            f"ubus call {DI_MOTOR} status", shell=True
        ).decode()
        return '"value": "1"' in out
    except:
        return motor_estado

# ================= MODBUS TCP =================

def leer_flotadores():
    if not client.connect():
        raise Exception("No conecta Modbus TCP")

    rr = client.read_discrete_inputs(0, 2, unit=MODBUS_ID)

    if rr.isError():
        raise Exception("Error lectura Modbus")

    return rr.bits[0], rr.bits[1]

# ================= INICIO =================

print(f"[{ts()}] 🚀 Sistema Pozo–Tanque iniciado (Modbus TCP)")

while True:
    try:
        # ===== LECTURA MODBUS =====
        flotador_bajo, flotador_alto = leer_flotadores()

        fallos_modbus = 0
        intervalo_actual = INTERVALO_NORMAL

        # ===== ESTADO MOTOR =====
        motor_estado = leer_motor_estado()
        ahora = time.time()

        # ===== LÓGICA =====
        if flotador_alto and not flotador_bajo:
            estado_proceso = "⚠️ Inconsistencia flotadores"
            if control_motor:
                set_motor(False, "Inconsistencia flotadores")

        elif flotador_alto and flotador_bajo:
            estado_proceso = "🟦 Tanque lleno"
            if control_motor:
                set_motor(False, "Tanque lleno")

        elif not flotador_bajo and not flotador_alto:
            if control_motor:
                estado_proceso = "💧 Llenando tanque"
            else:
                if tiempo_ultimo_apagado is None or \
                   (ahora - tiempo_ultimo_apagado) >= RETARDO_REARRANQUE:
                    estado_proceso = "▶️ Arranque permitido"
                    set_motor(True, "Tanque vacío")
                else:
                    restante = int(
                        RETARDO_REARRANQUE - (ahora - tiempo_ultimo_apagado)
                    )
                    estado_proceso = f"⏳ Esperando rearranque ({restante}s)"

        else:
            estado_proceso = "🟡 Nivel medio"

        # ===== CONSOLA =====
        print(
            f"[{ts()}] "
            f"🟢 Bajo: {flotador_bajo} | "
            f"🔵 Alto: {flotador_alto} | "
            f"🎛️ Control: {'ON' if control_motor else 'OFF'} | "
            f"⚙️ Motor: {'ON' if motor_estado else 'OFF'} | "
            f"{estado_proceso}"
        )

        time.sleep(intervalo_actual)

    except Exception as e:
        fallos_modbus += 1
        intervalo_actual = INTERVALO_ERROR

        print(
            f"[{ts()}] ❌ ERROR Modbus TCP ({fallos_modbus}/{MAX_FALLOS_MODBUS})"
        )

        if fallos_modbus >= MAX_FALLOS_MODBUS:
            estado_proceso = "❌ Falla comunicación Modbus TCP"
            if control_motor:
                set_motor(False, "Falla comunicación Modbus TCP")

            try:
                client.close()
            except:
                pass

            time.sleep(2)
            fallos_modbus = 0

        time.sleep(intervalo_actual)
